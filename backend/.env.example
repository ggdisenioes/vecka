# ──────────────────────────────────────────────────────────
#  VeCKA Backend — Variables de entorno
#  Copiar este archivo a .env y completar los valores reales
# ──────────────────────────────────────────────────────────

PORT=4000
FRONTEND_URL=http://localhost:5173

# JWT — usá un string largo y aleatorio en producción
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio_en_produccion

# ── MercadoPago ────────────────────────────────────────────
# Obtenelo en: https://www.mercadopago.com.ar/developers/panel/credentials
# Credenciales de TEST para desarrollo, PRODUCCION para live
MP_ACCESS_TOKEN=TEST-xxxxxxxxxxxxxxxxxxxx-xxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-xxxxxxxxx

# URL pública del backend para que MP llame el webhook.
# En desarrollo usar ngrok: ngrok http 4000  → poner la URL https aquí.
# En producción poner la URL real del servidor.
MP_WEBHOOK_URL=https://TU-DOMINIO.com/api/webhooks/mercadopago

# Secret del webhook (configuralo en el panel de MP → Webhooks)
MP_WEBHOOK_SECRET=

# ── Email (SMTP) ───────────────────────────────────────────
# Gmail: activar "Contraseñas de aplicación" en Seguridad de la cuenta
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu@gmail.com
SMTP_PASS=xxxx_xxxx_xxxx_xxxx
EMAIL_FROM=VeCKA <noreply@vecka.com.ar>

# ── Tienda ─────────────────────────────────────────────────
# Costo de envío fijo en ARS (Correo Argentino). Ajustar según destino.
SHIPPING_COST=3500

# Directorio donde están los PDFs de los moldes (relativo a backend/)
# Nombre de archivo esperado: product_<id>.pdf  (ej: product_101.pdf)
PDF_DIR=./uploads/pdfs

# ── Admin seed ─────────────────────────────────────────────
# Al iniciar el servidor se crea este admin si no existe
ADMIN_EMAIL=vero@vecka.com.ar
ADMIN_PASSWORD=cambia_esta_clave_admin
ADMIN_NAME=Vero (Admin)
